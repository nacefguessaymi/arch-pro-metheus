#!/usr/bin/env bash
# audio-toggle: switch between internal speakers and monitor HDMI/DP audio

CARD="alsa_card.pci-0000_00_1f.3"
CURRENT=$(pactl list cards | grep -A1 "Name: $CARD" | grep "Active Profile" | awk '{print $NF}')

if [[ "$CURRENT" == output:hdmi-stereo* ]]; then
    pactl set-card-profile "$CARD" output:analog-stereo+input:analog-stereo
    echo "Switched to internal speakers"
else
    pactl set-card-profile "$CARD" output:hdmi-stereo+input:analog-stereo
    echo "Switched to monitor speakers"
fi
